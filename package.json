{
  "name": "connect-four",
  "version": "1.0.0",
  "description": "Connect Four - Classic strategy game with AI opponent",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:sw && next dev --turbopack",
    "build": "npm run generate:sw && npm run build:wasm-assets && next build",
    "build:cf": "npm run generate:sw && npm run build:wasm-assets && npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "generate:sw": "GITHUB_SHA=$GITHUB_SHA node scripts/generate-sw.js",
    "build:wasm": "cd worker/rust_ai_core && wasm-pack build --target web --out-dir ../../public/wasm --features wasm",
    "build:wasm-assets": "npm run build:wasm && mkdir -p public/ml/data/genetic_params && cp resources/ai/evolved.json public/ml/data/genetic_params/ && mkdir -p public/ml/data/weights && python3 scripts/convert_model_for_wasm.py resources/ai/simple_model.json public/ml/data/weights/ml_ai_weights_simple.json",
    "build:rust-ai": "cd worker/rust_ai_core && cargo build --release",
    "nuke": "rm -rf .next .open-next .wrangler node_modules package-lock.json && npm install && npm run dev",
    "check": "npm run lint && npm run type-check && (cd worker/rust_ai_core && NUM_GAMES=4 cargo test test_ai_matrix -- --nocapture) && npm run test:coverage && npm run test:e2e",
    "check:slow": "npm run lint && npm run type-check && (cd worker/rust_ai_core && RUN_SLOW_TESTS=1 cargo test --features slow_tests -- --nocapture) && npm run test:coverage && npm run test:e2e",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cd worker/rust_ai_core && cargo test -- --nocapture",
    "test:rust:slow": "cd worker/rust_ai_core && RUN_SLOW_TESTS=1 cargo test --features slow_tests -- --nocapture",
    "test:ai-comparison": "./scripts/test-ai-comparison.sh",
    "test:ai-comparison:default": "NUM_GAMES=50 ./scripts/test-ai-comparison.sh",
    "test:ai-comparison:fast": "NUM_GAMES=10 ./scripts/test-ai-comparison.sh",
    "test:ai-comparison:comprehensive": "NUM_GAMES=100 INCLUDE_SLOW_TESTS=true ./scripts/test-ai-comparison.sh",
    "test:e2e": "npm run db:local:reset && playwright test --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "deps": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && npm run nuke",
    "db:local:reset": "tsx scripts/reset-local-db.ts",
    "db:setup": "npm run db:local:reset",
    "postinstall": "chmod +x scripts/*.sh",
    "migrate:generate": "drizzle-kit generate",
    "migrate:d1": "wrangler d1 migrations apply connect-four-db --remote",
    "migrate:local": "drizzle-kit push --config=drizzle.config.local.ts",
    "test:ai-matrix:md": "cd worker/rust_ai_core && cargo test test_ai_matrix -- --nocapture | node ../../scripts/format-ai-matrix-md.cjs",
    "deploy": "./scripts/deploy.sh",
    "deploy:quick": "npm run build:cf && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply connect-four-db --remote",
    "db:shell": "wrangler d1 execute connect-four-db --interactive",
    "logs": "wrangler tail --format pretty",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "immer": "^11.1.0",
    "lucide-react": "^0.562.0",
    "next": "15.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251224.0",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.2",
    "@opennextjs/cloudflare": "1.14.7",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "npm-check-updates": "^19.2.0",
    "prettier": "^3.7.4",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16",
    "wrangler": "4.56.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
